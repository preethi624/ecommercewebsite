<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coupon Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    :root {
      --green-dark: #1a3c2e;
      --green-mid: #2d6a4f;
      --green-bright: #52b788;
      --green-light: #d8f3dc;
      --surface: #faf7f0;
      --card-bg: #ffffff;
      --text-primary: #1c2b1e;
      --text-secondary: #6b8c78;
      --border: #c8ddd0;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--surface); color: var(--text-primary); min-height: 100vh; }
    .page-content { padding: 36px 44px 60px; background: var(--surface); min-height: 100%; }

    .breadcrumb-bar { display: flex; align-items: center; gap: 6px; font-size: 12.5px; color: var(--text-secondary); margin-bottom: 22px; flex-wrap: wrap; }
    .breadcrumb-bar a { color: var(--green-mid); text-decoration: none; font-weight: 500; }
    .breadcrumb-bar a:hover { color: var(--green-dark); }
    .breadcrumb-bar i { font-size: 9px; }

    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .page-header-left { display: flex; align-items: center; gap: 14px; }
    .page-header-icon { width: 48px; height: 48px; background: linear-gradient(135deg, var(--green-mid), var(--green-bright)); border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 19px; color: #fff; box-shadow: 0 4px 14px rgba(82,183,136,0.3); flex-shrink: 0; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: var(--green-dark); margin: 0; }
    .page-subtitle { font-size: 12.5px; color: var(--text-secondary); margin-top: 2px; }

    .form-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 24px 28px; margin-bottom: 24px; box-shadow: 0 4px 20px rgba(26,60,46,0.07); }
    .form-card-title { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; color: var(--green-dark); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .form-card-title .title-icon { width: 32px; height: 32px; background: var(--green-light); border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; font-size: 14px; color: var(--green-mid); flex-shrink: 0; }

    .form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-secondary); }
    .form-control, select.form-control { background: var(--surface); border: 1.5px solid var(--border); border-radius: 10px; color: var(--text-primary); padding: 9px 14px; font-size: 13px; font-family: 'DM Sans', sans-serif; width: 100%; transition: border-color 0.2s, box-shadow 0.2s; -webkit-appearance: none; appearance: none; }
    .form-control:focus, select.form-control:focus { outline: none; border-color: var(--green-bright); box-shadow: 0 0 0 3px rgba(82,183,136,0.13); background: #fff; }
    .form-control::placeholder { color: #a8beaf; }
    input[type="date"]::-webkit-calendar-picker-indicator { opacity: 0.4; cursor: pointer; }
    .text-danger { color: #c0392b !important; font-size: 11.5px; margin-top: 3px; }
    .form-full { grid-column: 1 / -1; }

    .btn-create { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, var(--green-dark), var(--green-mid)); color: #fff; border: none; padding: 10px 24px; border-radius: 50px; font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; box-shadow: 0 4px 14px rgba(26,60,46,0.2); transition: transform 0.15s, box-shadow 0.15s, opacity 0.2s; margin-top: 4px; }
    .btn-create:hover { opacity: 0.88; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(26,60,46,0.28); }

    .table-scroll { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .table-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(26,60,46,0.07); }
    .table-card-header { padding: 18px 22px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid #eef4f0; }
    .table-card-header .title-icon { width: 32px; height: 32px; background: var(--green-light); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--green-mid); flex-shrink: 0; }
    .table-card-header .title-text { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; color: var(--green-dark); }
    .table-card table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 800px; }
    .table-card thead tr { background: linear-gradient(135deg, var(--green-dark), var(--green-mid)); }
    .table-card thead th { color: rgba(255,255,255,0.92); font-weight: 600; font-size: 11px; letter-spacing: 0.5px; text-transform: uppercase; padding: 13px 14px; white-space: nowrap; border: none; }
    .table-card tbody tr { border-bottom: 1px solid #eef4f0; transition: background 0.15s; }
    .table-card tbody tr:last-child { border-bottom: none; }
    .table-card tbody tr:hover { background: #f5fbf7; }
    .table-card tbody td { padding: 11px 14px; color: var(--text-primary); vertical-align: middle; border: none; }

    .code-pill { display: inline-block; background: linear-gradient(135deg, var(--green-dark), var(--green-mid)); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 11.5px; font-weight: 700; letter-spacing: 0.08em; padding: 4px 12px; border-radius: 6px; }
    .type-badge { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; border-radius: 50px; padding: 3px 10px; white-space: nowrap; text-transform: capitalize; }
    .type-percentage { background: var(--green-light); color: var(--green-dark); }
    .type-flat { background: #fff3cd; color: #856404; }
    .value-cell { font-weight: 700; color: var(--green-dark); }

    .action-btn { display: inline-flex; align-items: center; gap: 4px; padding: 5px 11px; border-radius: 7px; font-size: 11.5px; font-weight: 600; font-family: 'DM Sans', sans-serif; border: none; cursor: pointer; text-decoration: none; transition: opacity 0.18s, transform 0.13s; white-space: nowrap; }
    .action-btn:hover { opacity: 0.82; transform: translateY(-1px); }
    .btn-delete { background: #fde8e8; color: #c0392b; }

    .pagination-wrap { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 24px; padding-bottom: 8px; flex-wrap: wrap; }
    .pg-info { width: 100%; text-align: center; font-size: 12px; color: var(--text-secondary); margin-bottom: 8px; }
    .pg-info strong { color: var(--green-mid); }
    .pagination-wrap button { display: inline-flex; align-items: center; justify-content: center; min-width: 36px; height: 36px; padding: 0 10px; border-radius: 9px; font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif; border: 1.5px solid var(--border); background: var(--card-bg); color: var(--text-primary); cursor: pointer; transition: background 0.18s, border-color 0.18s, color 0.18s; }
    .pagination-wrap button:hover:not(:disabled):not(.pg-active) { background: var(--green-light); border-color: var(--green-bright); color: var(--green-dark); }
    .pagination-wrap button.pg-active { background: linear-gradient(135deg, var(--green-mid), var(--green-bright)); border-color: transparent; color: #fff; }
    .pagination-wrap button:disabled { opacity: 0.3; cursor: not-allowed; }

    .empty-state { text-align: center; padding: 60px 20px; color: var(--text-secondary); }
    .empty-state i { font-size: 40px; color: var(--green-light); margin-bottom: 14px; display: block; }
    .empty-state p { font-size: 14px; }

    @media (max-width: 1100px) { .page-content { padding: 28px 24px 48px; } }
    @media (max-width: 768px) { .page-content { padding: 20px 16px 40px; } .page-title { font-size: 20px; } .form-card { padding: 18px 16px; } }
    @media (max-width: 576px) { .page-content { padding: 14px 10px 36px; } .page-title { font-size: 18px; } .page-subtitle { display: none; } .page-header-icon { width: 38px; height: 38px; font-size: 15px; } .action-btn { padding: 4px 8px; font-size: 11px; } .pagination-wrap button { min-width: 32px; height: 32px; font-size: 12px; } }
  </style>
</head>

<body>
  <%- include("../../views/partials/admin/header") %>

  <div class="page-content">

    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
      <a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
      <i class="fas fa-chevron-right"></i>
      <span>Coupons</span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-left">
        <div class="page-header-icon"><i class="fas fa-ticket-alt"></i></div>
        <div>
          <h2 class="page-title">Coupons</h2>
          <p class="page-subtitle">Create &amp; manage discount codes</p>
        </div>
      </div>
    </div>

    <!-- Create Coupon Form -->
    <div class="form-card">
      <div class="form-card-title">
        <span class="title-icon"><i class="fas fa-plus"></i></span>
        Create New Coupon
      </div>
      <form action="/admin/create-coupon" method="POST" onsubmit="return validateForm()">
        <div class="form-grid">

          <div class="form-group">
            <label for="code">Coupon Code</label>
            <input type="text" name="code" id="code" class="form-control" placeholder="e.g. SAVE20">
            <small id="codeError" class="text-danger" style="display:none;"></small>
          </div>

          <div class="form-group">
            <label for="discountType">Discount Type</label>
            <select name="discountType" id="discountType" class="form-control">
              <option value="percentage">Percentage</option>
              <option value="flat">Flat</option>
            </select>
          </div>

          <div class="form-group">
            <label for="discountValue">Discount Value</label>
            <input type="number" name="discountValue" id="discountValue" class="form-control" placeholder="e.g. 15">
            <small id="discountValueError" class="text-danger" style="display:none;"></small>
          </div>

          <div class="form-group">
            <label for="minPurchaseAmount">Min Purchase <span style="font-weight:400;text-transform:none;letter-spacing:0">(Optional)</span></label>
            <input type="number" name="minPurchaseAmount" id="minPurchaseAmount" class="form-control" placeholder="e.g. 500">
            <small id="minPurchaseAmountError" class="text-danger" style="display:none;"></small>
          </div>

          <div class="form-group">
            <label for="maxDiscount">Max Discount <span style="font-weight:400;text-transform:none;letter-spacing:0">(Optional)</span></label>
            <input type="number" name="maxDiscount" id="maxDiscount" class="form-control" placeholder="e.g. 200">
            <small id="maxDiscountError" class="text-danger" style="display:none;"></small>
          </div>

          <div class="form-group">
            <label for="expiryDate">Expiry Date</label>
            <input type="date" name="expiryDate" id="expiryDate" class="form-control">
          </div>

          <div class="form-group">
            <label for="usageLimit">Usage Limit</label>
            <input type="number" name="usageLimit" id="usageLimit" class="form-control" placeholder="e.g. 100">
            <small id="usageLimitError" class="text-danger" style="display:none;"></small>
          </div>

          <div class="form-group form-full">
            <button type="submit" class="btn-create">
              <i class="fas fa-plus"></i> Create Coupon
            </button>
          </div>

        </div>
      </form>
    </div>

    <!-- Existing Coupons Table -->
    <div class="table-card">
      <div class="table-card-header">
        <div class="title-icon"><i class="fas fa-list"></i></div>
        <span class="title-text">Existing Coupons</span>
      </div>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Code</th>
              <th>Type</th>
              <th>Value</th>
              <th>Min Purchase</th>
              <th>Max Discount</th>
              <th>Expiry</th>
              <th>Usage Limit</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="couponTableBody">
            <% if (coupons && coupons.length > 0) { %>
              <% coupons.forEach(coupon => { %>
                <tr data-row>
                  <td><span class="code-pill"><%= coupon.code %></span></td>
                  <td>
                    <span class="type-badge <%= coupon.discountType === 'percentage' ? 'type-percentage' : 'type-flat' %>">
                      <% if (coupon.discountType === 'percentage') { %>
                        <i class="fas fa-percent" style="font-size:9px"></i>
                      <% } else { %>
                        <i class="fas fa-rupee-sign" style="font-size:9px"></i>
                      <% } %>
                      <%= coupon.discountType %>
                    </span>
                  </td>
                  <td><span class="value-cell"><%= coupon.discountValue %></span></td>
                  <td><%= coupon.minPurchaseAmount || '—' %></td>
                  <td><%= coupon.maxDiscount || '—' %></td>
                  <td><%= new Date(coupon.expiryDate).toLocaleDateString() %></td>
                  <td><%= coupon.usageLimit %></td>
                  <td>
                    <form action="/admin/delete-coupon/<%= coupon._id %>" method="POST" style="display:inline;">
                      <button type="submit" class="action-btn btn-delete">
                        <i class="fas fa-trash-alt"></i> Delete
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="8">
                  <div class="empty-state">
                    <i class="fas fa-ticket-alt"></i>
                    <p>No coupons found. Create your first coupon above.</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="pagination-wrap">
        <div class="pg-info" id="pgInfo"></div>
        <div id="pgControls" style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;"></div>
      </div>
    </div>

  </div><!-- /page-content -->

  <%- include("../../views/partials/admin/footer") %>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script>
    function validateForm() {
      let isValid = true;
      ['codeError','discountValueError','minPurchaseAmountError','maxDiscountError','usageLimitError'].forEach(id => {
        document.getElementById(id).style.display = 'none';
      });
      if (!document.getElementById('code').value.trim()) {
        document.getElementById('codeError').textContent = 'Coupon code cannot be blank.';
        document.getElementById('codeError').style.display = 'block';
        isValid = false;
      }
      if (!document.getElementById('discountValue').value.trim()) {
        document.getElementById('discountValueError').textContent = 'Discount value cannot be blank.';
        document.getElementById('discountValueError').style.display = 'block';
        isValid = false;
      }
      if (!document.getElementById('usageLimit').value.trim()) {
        document.getElementById('usageLimitError').textContent = 'Usage limit cannot be blank.';
        document.getElementById('usageLimitError').style.display = 'block';
        isValid = false;
      }
      return isValid;
    }

    const ROWS_PER_PAGE = 7;
    let currentPage = 1;
    const allRows = Array.from(document.querySelectorAll('[data-row]'));
    const totalPages = Math.ceil(allRows.length / ROWS_PER_PAGE);
    const pgInfo = document.getElementById('pgInfo');
    const pgControls = document.getElementById('pgControls');

    function showPage(page) {
      currentPage = page;
      const start = (page - 1) * ROWS_PER_PAGE;
      const end = start + ROWS_PER_PAGE;
      allRows.forEach((row, i) => { row.style.display = (i >= start && i < end) ? '' : 'none'; });
      const showing = Math.min(end, allRows.length);
      pgInfo.innerHTML = allRows.length > 0 ? 'Showing <strong>' + (start + 1) + '–' + showing + '</strong> of <strong>' + allRows.length + '</strong> coupons' : '';
      renderControls();
    }

    function renderControls() {
      if (totalPages <= 1) { pgControls.innerHTML = ''; return; }
      let html = '';
      html += '<button onclick="showPage(' + (currentPage - 1) + ')" ' + (currentPage === 1 ? 'disabled' : '') + '>&#8592;</button>';
      const range = [];
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) range.push(i);
        else if (range[range.length - 1] !== '...') range.push('...');
      }
      range.forEach(item => {
        if (item === '...') html += '<span style="color:var(--text-secondary);padding:0 4px;">···</span>';
        else html += '<button class="' + (item === currentPage ? 'pg-active' : '') + '" onclick="showPage(' + item + ')">' + item + '</button>';
      });
      html += '<button onclick="showPage(' + (currentPage + 1) + ')" ' + (currentPage === totalPages ? 'disabled' : '') + '>&#8594;</button>';
      pgControls.innerHTML = html;
    }

    if (allRows.length > 0) showPage(1);
  </script>
</body>
</html>