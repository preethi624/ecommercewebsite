<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --green-dark: #1a3c2e;
            --green-mid: #2d6a4f;
            --green-bright: #52b788;
            --green-light: #d8f3dc;
            --surface: #faf7f0;
            --card-bg: #ffffff;
            --text-primary: #1c2b1e;
            --text-secondary: #6b8c78;
            --border: #c8ddd0;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--surface);
            color: var(--text-primary);
            min-height: 100vh;
        }

        .page-content {
            padding: 36px 44px 60px;
            background: var(--surface);
            min-height: 100%;
        }

        /* ── BREADCRUMB ── */
        .breadcrumb-bar {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12.5px;
            color: var(--text-secondary);
            margin-bottom: 22px;
            flex-wrap: wrap;
        }
        .breadcrumb-bar a { color: var(--green-mid); text-decoration: none; font-weight: 500; }
        .breadcrumb-bar a:hover { color: var(--green-dark); }
        .breadcrumb-bar i { font-size: 9px; }

        /* ── PAGE HEADER ── */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .page-header-icon {
            width: 48px; height: 48px;
            background: linear-gradient(135deg, var(--green-mid), var(--green-bright));
            border-radius: 13px;
            display: flex; align-items: center; justify-content: center;
            font-size: 19px; color: #fff;
            box-shadow: 0 4px 14px rgba(82,183,136,0.3);
            flex-shrink: 0;
        }
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--green-dark);
            margin: 0;
        }
        .page-subtitle {
            font-size: 12.5px;
            color: var(--text-secondary);
            margin-top: 2px;
        }
        .btn-add-product {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            box-shadow: 0 4px 14px rgba(26,60,46,0.2);
            transition: transform 0.15s, box-shadow 0.15s;
            white-space: nowrap;
        }
        .btn-add-product:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(26,60,46,0.28);
        }

        /* ── SEARCH CARD ── */
        .search-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 16px 20px;
            margin-bottom: 22px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: 0 2px 10px rgba(26,60,46,0.05);
        }
        .search-input-wrap {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 50px;
            padding: 9px 18px;
            transition: border-color 0.2s, box-shadow 0.2s;
            min-width: 0;
        }
        .search-input-wrap:focus-within {
            border-color: var(--green-bright);
            box-shadow: 0 0 0 3px rgba(82,183,136,0.13);
        }
        .search-input-wrap i { color: var(--text-secondary); font-size: 13px; flex-shrink: 0; }
        .search-input-wrap input {
            border: none;
            background: transparent;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: var(--text-primary);
            width: 100%;
            min-width: 0;
        }
        .search-input-wrap input::placeholder { color: #a8beaf; }
        .btn-search {
            background: linear-gradient(135deg, var(--green-mid), var(--green-bright));
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            display: flex; align-items: center; gap: 7px;
            transition: opacity 0.2s, transform 0.15s;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .btn-search:hover { opacity: 0.88; transform: translateY(-1px); }

        /* ── TABLE SCROLL WRAPPER ── */
        .table-scroll {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        /* ── TABLE CARD ── */
        .table-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(26,60,46,0.07);
        }
        .table-card table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            min-width: 900px; /* prevents squish on small screens */
        }
        .table-card thead tr {
            background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
        }
        .table-card thead th {
            color: rgba(255,255,255,0.92);
            font-weight: 600;
            font-size: 11px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            padding: 13px 14px;
            white-space: nowrap;
            border: none;
        }
        .table-card tbody tr {
            border-bottom: 1px solid #eef4f0;
            transition: background 0.15s;
        }
        .table-card tbody tr:last-child { border-bottom: none; }
        .table-card tbody tr:hover { background: #f5fbf7; }
        .table-card tbody td {
            padding: 11px 14px;
            color: var(--text-primary);
            vertical-align: middle;
            border: none;
        }

        /* ── CELLS ── */
        .product-name-cell {
            font-weight: 600;
            color: var(--green-dark);
            font-size: 13px;
            white-space: nowrap;
        }
        .cat-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--green-light);
            color: var(--green-dark);
            font-size: 11px;
            font-weight: 600;
            border-radius: 50px;
            padding: 3px 10px;
            white-space: nowrap;
        }
        .price-regular { color: var(--text-secondary); font-size: 12.5px; white-space: nowrap; }
        .price-sale { color: var(--green-dark); font-weight: 700; font-size: 13px; white-space: nowrap; }
        .offer-badge {
            display: inline-block;
            background: #fff3cd;
            color: #856404;
            font-size: 10.5px;
            font-weight: 700;
            border-radius: 5px;
            padding: 2px 7px;
            white-space: nowrap;
        }
        .product-img {
            width: 48px; height: 48px;
            border-radius: 9px;
            object-fit: cover;
            border: 2px solid var(--green-light);
            flex-shrink: 0;
        }
        .no-img {
            width: 48px; height: 48px;
            border-radius: 9px;
            background: var(--green-light);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
            color: var(--green-bright);
            border: 2px dashed var(--border);
            flex-shrink: 0;
        }
        .qty-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #f0f8f3;
            border: 1px solid var(--border);
            color: var(--green-dark);
            font-size: 12px;
            font-weight: 600;
            border-radius: 7px;
            padding: 3px 9px;
            white-space: nowrap;
        }

        /* ── ACTION BUTTONS ── */
        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 5px 11px;
            border-radius: 7px;
            font-size: 11.5px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.18s, transform 0.13s;
            white-space: nowrap;
            margin: 2px 1px;
        }
        .action-btn:hover { opacity: 0.82; transform: translateY(-1px); }
        .btn-block        { background: #fde8e8; color: #c0392b; }
        .btn-unblock      { background: #e8f7ee; color: #1a6640; }
        .btn-edit         { background: var(--green-light); color: var(--green-dark); }
        .btn-delete       { background: #fde8e8; color: #c0392b; }
        .btn-add-offer    { background: #e8f0fe; color: #2563eb; }
        .btn-remove-offer { background: #fff3cd; color: #856404; }

        /* ── SOFT DELETE LINK ── */
        .soft-delete-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-secondary);
            font-size: 12.5px;
            text-decoration: none;
            margin-top: 16px;
            padding: 7px 14px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            transition: color 0.18s, border-color 0.18s;
        }
        .soft-delete-link:hover { color: var(--green-dark); border-color: var(--green-bright); }

        /* ── PAGINATION ── */
        .pagination-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            margin-top: 24px;
            flex-wrap: wrap;
        }
        .pagination-wrap a,
        .pagination-wrap span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 36px; height: 36px;
            padding: 0 10px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            border: 1.5px solid var(--border);
            background: var(--card-bg);
            color: var(--text-primary);
            transition: background 0.18s, border-color 0.18s, color 0.18s;
        }
        .pagination-wrap a:hover {
            background: var(--green-light);
            border-color: var(--green-bright);
            color: var(--green-dark);
        }
        .pagination-wrap span.current-page {
            background: linear-gradient(135deg, var(--green-mid), var(--green-bright));
            border-color: transparent;
            color: #fff;
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-secondary);
        }
        .empty-state i { font-size: 40px; color: var(--green-light); margin-bottom: 14px; display: block; }
        .empty-state p { font-size: 14px; }

        /* ══════════════════════════════
           RESPONSIVE BREAKPOINTS
        ══════════════════════════════ */

        /* Large tablet */
        @media (max-width: 1100px) {
            .page-content { padding: 28px 24px 48px; }
        }

        /* Tablet */
        @media (max-width: 768px) {
            .page-content { padding: 20px 16px 40px; }
            .page-title { font-size: 20px; }
            .page-header { gap: 12px; }
            .search-card { padding: 12px 14px; gap: 10px; }
            .btn-search span { display: none; } /* icon only */
            .btn-search { padding: 10px 14px; }
        }

        /* Mobile */
        @media (max-width: 576px) {
            .page-content { padding: 14px 10px 36px; }
            .page-title { font-size: 18px; }
            .page-subtitle { display: none; }
            .page-header-icon { width: 38px; height: 38px; font-size: 15px; }

            .search-card { flex-wrap: wrap; padding: 10px 12px; }
            .search-card form { width: 100%; }

            .btn-add-product { padding: 8px 16px; font-size: 12px; }
            .btn-add-product span { display: none; }

            .action-btn { padding: 4px 8px; font-size: 11px; }

            .pagination-wrap a,
            .pagination-wrap span { min-width: 32px; height: 32px; font-size: 12px; }

            .soft-delete-link { font-size: 12px; padding: 6px 11px; }
        }
    </style>
</head>

<body>
    <%- include("../../views/partials/admin/header") %>

    <div class="page-content">

        <!-- Breadcrumb -->
        <div class="breadcrumb-bar">
            <a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <i class="fas fa-chevron-right"></i>
            <span>Products</span>
        </div>

        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left">
                <div class="page-header-icon"><i class="fas fa-box-open"></i></div>
                <div>
                    <h2 class="page-title">Products</h2>
                    <p class="page-subtitle">Manage your store's product catalogue</p>
                </div>
            </div>
            <a href="/admin/addProducts" class="btn-add-product">
                <i class="fas fa-plus"></i> <span>Add Product</span>
            </a>
        </div>

        <!-- Search -->
        <div class="search-card">
            <form action="" method="get" style="display:flex;align-items:center;gap:12px;width:100%;">
                <div class="search-input-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" name="search" placeholder="Search products or brands...">
                </div>
                <button type="submit" class="btn-search">
                    <i class="fas fa-search"></i> <span>Search</span>
                </button>
            </form>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th>Regular Price</th>
                            <th>Offer %</th>
                            <th>Offer</th>
                            <th>Sale Price</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Edit</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data && data.length > 0) { %>
                            <% for(let i = data.length-1; i >= 0; i--) { %>
                            <tr>
                                <td>
                                    <% if (data[i].productImage && data[i].productImage.length > 0) { %>
                                        <img src="/uploads/product-images/<%= data[i].productImage[0] %>" alt="Product" class="product-img">
                                    <% } else { %>
                                        <div class="no-img"><i class="fas fa-image"></i></div>
                                    <% } %>
                                </td>
                                <td><span class="product-name-cell"><%= data[i].productName %></span></td>
                                <td><span class="cat-badge"><i class="fas fa-leaf" style="font-size:9px"></i> <%= data[i].category.name %></span></td>
                                <td><span class="price-regular">₹<%= data[i].regularPrice %></span></td>
                                <td>
                                    <% if(locals.data[i].productOffer) { %>
                                        <span class="offer-badge"><%= data[i].productOffer %>%</span>
                                    <% } else { %>
                                        <span style="color:var(--text-secondary);">—</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (locals.data[i].productOffer === 0) { %>
                                        <button class="action-btn btn-add-offer" onclick="addOffer('<%= data[i]._id %>')">
                                            <i class="fas fa-tag"></i> Add Offer
                                        </button>
                                    <% } else { %>
                                        <button class="action-btn btn-remove-offer" onclick="removeOffer('<%= data[i]._id %>')">
                                            <i class="fas fa-times"></i> Remove
                                        </button>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="price-sale">₹<% if(locals.data[i].category.categoryOffer) { %><%= data[i].regularPrice - ((data[i].regularPrice * data[i].category.categoryOffer) / 100) %><% } else if(locals.data[i].productOffer) { %><%= data[i].regularPrice - ((data[i].regularPrice * data[i].productOffer) / 100) %><% } else { %><%= data[i].regularPrice %><% } %></span>
                                </td>
                                <td><span class="qty-badge"><i class="fas fa-weight" style="font-size:10px"></i> <%= data[i].quantity %> kg</span></td>
                                <td>
                                    <button class="action-btn btn-block"><i class="fas fa-ban"></i> Block</button>
                                    <button class="action-btn btn-unblock"><i class="fas fa-check"></i> Unblock</button>
                                </td>
                                <td>
                                    <a href="/admin/editProduct?id=<%= data[i]._id %>" class="action-btn btn-edit">
                                        <i class="fas fa-pen"></i> Edit
                                    </a>
                                </td>
                                <td>
                                    <button class="action-btn btn-delete" onclick="softDeleteProduct('<%= data[i]._id %>')">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </button>
                                </td>
                            </tr>
                            <% } %>
                        <% } else { %>
                            <tr>
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="fas fa-box-open"></i>
                                        <p>No products found. Try a different search or add a new product.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <a href="/admin/softProducts" class="soft-delete-link">
            <i class="fas fa-trash-restore"></i> View soft deleted products
        </a>

        <!-- Pagination -->
        <div class="pagination-wrap">
            <% if (currentPage > 1) { %>
                <a href="?page=<%= currentPage - 1 %>"><i class="fas fa-chevron-left"></i> Prev</a>
            <% } %>
            <% for (let i = 1; i <= totalPages; i++) { %>
                <% if (i === currentPage) { %>
                    <span class="current-page"><%= i %></span>
                <% } else { %>
                    <a href="?page=<%= i %>"><%= i %></a>
                <% } %>
            <% } %>
            <% if (currentPage < totalPages) { %>
                <a href="?page=<%= currentPage + 1 %>">Next <i class="fas fa-chevron-right"></i></a>
            <% } %>
        </div>

    </div><!-- /page-content -->

    <%- include("../../views/partials/admin/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        async function addOffer(productId) {
            const { value: amount } = await Swal.fire({
                title: 'Offer in percentage',
                input: 'number',
                inputLabel: 'percentage',
                inputPlaceholder: '%',
            });
            $.ajax({
                url: "/admin/addProductOffer",
                method: 'post',
                data: { percentage: amount, productId: productId },
                success: (response) => {
                    if (response.status === true) {
                        location.reload();
                        Swal.fire('Offer added', 'The offer has been added', 'success');
                    } else {
                        Swal.fire({ title: 'Failed', text: 'Failed to add the offer.', icon: 'error' });
                    }
                }
            });
        }

        async function removeOffer(productId) {
            try {
                Swal.fire({
                    title: 'Remove offer',
                    text: 'Are you sure you want to remove this offer?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, remove it!',
                    timer: 5000,
                    timerProgressBar: true
                }).then(async (result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: "/admin/removeProductOffer",
                            method: 'post',
                            data: { productId: productId },
                            success: (response) => {
                                if (response.status === true) {
                                    Swal.fire("Removed!", "The offer has been removed", "success");
                                    location.reload();
                                } else {
                                    Swal.fire('Failed', 'Could not remove offer.', 'error');
                                }
                            }
                        });
                    }
                });
            } catch (error) { console.error(error); }
        }

        async function softDeleteProduct(productId) {
            try {
                Swal.fire({
                    title: 'Delete Product',
                    text: 'Are you sure you want to delete this product?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, delete it!',
                }).then(async (result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/admin/softDeleteProduct',
                            method: 'post',
                            data: { productId: productId },
                            success: (response) => {
                                if (response.status === true) {
                                    Swal.fire('Deleted!', 'The product has been deleted.', 'success');
                                    location.reload();
                                } else {
                                    Swal.fire('Error', 'Failed to delete the product.', 'error');
                                }
                            },
                        });
                    }
                });
            } catch (error) { console.error(error); }
        }
    </script>
</body>
</html>