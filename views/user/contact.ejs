<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Organic Store</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/home.css">

    <style>
        :root {
            --green-dark:  #1a3c2e;
            --green-mid:   #2d6a4f;
            --green-light: #52b788;
            --green-pale:  #d8f3dc;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', Arial, sans-serif;
            background: #f4f7f5;
            color: #1a3c2e;
            min-height: 100vh;
        }

        /* ── HERO BANNER ── */
        .contact-hero {
            background: linear-gradient(135deg, #1a3c2e 0%, #2d6a4f 60%, #52b788 100%);
            padding: 72px 24px 110px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .contact-hero::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 260px; height: 260px;
            border-radius: 50%;
            background: rgba(82, 183, 136, 0.15);
        }
        .contact-hero::after {
            content: '';
            position: absolute;
            bottom: -80px; left: -40px;
            width: 200px; height: 200px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,0.14);
            border: 1px solid rgba(255,255,255,0.22);
            border-radius: 100px;
            padding: 6px 16px;
            color: rgba(255,255,255,0.90);
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
            position: relative;
            z-index: 1;
        }
        .contact-hero h1 {
            font-size: 2.6rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 12px;
            position: relative;
            z-index: 1;
        }
        .contact-hero p {
            font-size: 1.05rem;
            color: rgba(255,255,255,0.78);
            max-width: 480px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* ── MAIN LAYOUT ── */
        .contact-wrapper {
            max-width: 900px;
            margin: -52px auto 60px;
            padding: 0 24px;
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
            align-items: start;
        }
        @media (max-width: 760px) {
            .contact-wrapper {
                grid-template-columns: 1fr;
                margin-top: -28px;
            }
            .contact-hero h1 { font-size: 2rem; }
        }

        /* ── INFO CARDS ── */
        .info-card {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(26,60,46,0.10);
            padding: 28px 24px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .info-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 36px rgba(26,60,46,0.14);
        }
        .info-card h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--green-dark);
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1.5px solid var(--green-pale);
        }

        /* Contact items */
        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid #eef4f0;
        }
        .contact-item:last-child { border-bottom: none; padding-bottom: 0; }
        .contact-item:first-of-type { padding-top: 0; }

        .contact-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--green-pale);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--green-mid);
            font-size: 15px;
            flex-shrink: 0;
        }
        .contact-item-text strong {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--green-dark);
            margin-bottom: 3px;
        }
        .contact-item-text span {
            font-size: 13px;
            color: #6b8a78;
            line-height: 1.5;
        }

        /* Hours */
        .hours-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            padding: 8px 0;
            border-bottom: 1px dashed #eef4f0;
            gap: 8px;
        }
        .hours-row:last-child { border-bottom: none; }
        .hours-row .day { color: #6b8a78; flex: 1; }
        .hours-row .time { font-weight: 500; color: var(--green-dark); font-size: 12px; }
        .badge-open {
            font-size: 11px;
            font-weight: 600;
            background: var(--green-pale);
            color: var(--green-mid);
            border-radius: 100px;
            padding: 2px 8px;
            white-space: nowrap;
        }
        .badge-closed {
            font-size: 11px;
            font-weight: 600;
            background: #fce8e8;
            color: #c0392b;
            border-radius: 100px;
            padding: 2px 8px;
            white-space: nowrap;
        }

        /* Social */
        .social-links {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 4px;
        }
        .social-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--green-pale);
            color: var(--green-mid);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            text-decoration: none;
            transition: background 0.18s, color 0.18s, transform 0.15s;
        }
        .social-btn:hover {
            background: var(--green-light);
            color: #fff;
            text-decoration: none;
            transform: translateY(-2px);
        }

        /* ── MAP STRIP ── */
        .map-strip {
            max-width: 900px;
            margin: 0 auto 60px;
            padding: 0 24px;
        }
        .map-strip iframe {
            width: 100%;
            height: 280px;
            border: none;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(26,60,46,0.10);
            display: block;
        }
    </style>
</head>
<body>

    <%- include("../../views/partials/user/header") %>

    <!-- HERO -->
    <div class="contact-hero">
        <div class="hero-badge">
            <i class="fas fa-leaf" style="font-size:12px;"></i> We'd love to hear from you
        </div>
        <h1>Get in Touch</h1>
        <p>Have questions or need assistance? Our friendly team is always here to help you.</p>
    </div>

    <!-- INFO CARDS -->
    <div class="contact-wrapper">

        <!-- Card 1: Contact Details -->
        <div class="info-card">
            <h3><i class="fas fa-address-book" style="color:var(--green-light); margin-right:8px;"></i>Contact Details</h3>

            <div class="contact-item">
                <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                <div class="contact-item-text">
                    <strong>Email</strong>
                    <span>support@organicstore.com</span>
                </div>
            </div>

            <div class="contact-item">
                <div class="contact-icon"><i class="fas fa-phone"></i></div>
                <div class="contact-item-text">
                    <strong>Phone</strong>
                    <span>+1 (123) 456-7890</span>
                </div>
            </div>

            <div class="contact-item">
                <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
                <div class="contact-item-text">
                    <strong>Address</strong>
                    <span>123 Organic Street, Green City, Planet Earth</span>
                </div>
            </div>
        </div>

        <!-- Card 2: Business Hours -->
        <div class="info-card">
            <h3><i class="fas fa-clock" style="color:var(--green-light); margin-right:8px;"></i>Business Hours</h3>

            <div class="hours-row">
                <span class="day">Mon – Fri</span>
                <span class="time">9:00 AM – 6:00 PM</span>
                <span class="badge-open">Open</span>
            </div>
            <div class="hours-row">
                <span class="day">Saturday</span>
                <span class="time">10:00 AM – 4:00 PM</span>
                <span class="badge-open">Open</span>
            </div>
            <div class="hours-row">
                <span class="day">Sunday</span>
                <span class="time">Closed</span>
                <span class="badge-closed">Closed</span>
            </div>
        </div>

        <!-- Card 3: Follow Us -->
        <div class="info-card">
            <h3><i class="fas fa-share-alt" style="color:var(--green-light); margin-right:8px;"></i>Follow Us</h3>
            <p style="font-size:13px; color:#6b8a78; margin-bottom:18px; line-height:1.6;">
                Stay connected for organic tips, fresh arrivals, and exclusive offers.
            </p>
            <div class="social-links">
                <a href="#" class="social-btn"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="social-btn"><i class="fab fa-instagram"></i></a>
                <a href="#" class="social-btn"><i class="fab fa-twitter"></i></a>
                <a href="#" class="social-btn"><i class="fab fa-youtube"></i></a>
            </div>
        </div>

    </div>

   
    

    <%- include("../../views/partials/user/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>