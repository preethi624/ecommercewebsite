<%-include("../../views/partials/user/header")%>
 <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">


<style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --green-900: #0f2d1a;
        --green-800: #1a4228;
        --green-700: #245c38;
        --green-500: #3a8c52;
        --green-400: #52b06e;
        --green-200: #b2dfca;
        --gold:       #c8973a;
        --cream:      #faf8f4;
        --white:      #ffffff;
        --text-dark:  #0f2d1a;
        --text-light: #7aaa8a;
        --border:     #d4e9dc;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--green-900);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }
   
    .login-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
        position: relative;
        overflow: hidden;
    }

    .bg-orb { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(80px); opacity: 0.18; }
    .bg-orb-1 { width: 600px; height: 600px; background: radial-gradient(circle, #3a8c52, transparent 70%); top: -150px; left: -150px; animation: drift 18s ease-in-out infinite; }
    .bg-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, #c8973a, transparent 70%); bottom: -100px; right: -100px; animation: drift 22s ease-in-out infinite reverse; }
    @keyframes drift {
        0%,100% { transform: translate(0,0) scale(1); }
        33%      { transform: translate(40px,-30px) scale(1.08); }
        66%      { transform: translate(-25px,40px) scale(0.94); }
    }

    .login-card {
        position: relative;
        display: flex;
        width: 100%;
        max-width: 900px;
        min-height: 560px;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 30px 80px rgba(0,0,0,0.55);
        animation: reveal 0.75s cubic-bezier(0.16,1,0.3,1) both;
        z-index: 1;
    }
    @keyframes reveal {
        from { opacity: 0; transform: translateY(30px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Image Panel */
    .panel-image { width: 42%; position: relative; overflow: hidden; flex-shrink: 0; }
    .panel-image img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 10s ease; }
    .login-card:hover .panel-image img { transform: scale(1.06); }
    .panel-image-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(160deg, rgba(15,45,26,0.6) 0%, rgba(15,45,26,0.2) 50%, rgba(200,151,58,0.2) 100%);
    }

    .badge-organic {
        position: absolute; top: 20px; left: 20px; z-index: 4;
        display: flex; align-items: center; gap: 7px;
        background: rgba(15,45,26,0.75); backdrop-filter: blur(12px);
        border: 1px solid rgba(82,176,110,0.35); border-radius: 100px;
        padding: 5px 14px 5px 8px;
    }
    .badge-organic .pulse {
        width: 9px; height: 9px; border-radius: 50%; background: var(--green-400);
        box-shadow: 0 0 0 3px rgba(82,176,110,0.25);
        animation: blink 2.2s ease-in-out infinite;
    }
    @keyframes blink {
        0%,100% { box-shadow: 0 0 0 3px rgba(82,176,110,0.25); }
        50%      { box-shadow: 0 0 0 7px rgba(82,176,110,0.08); }
    }
    .badge-organic span { font-size: 0.72rem; font-weight: 500; color: var(--green-200); letter-spacing: 0.07em; text-transform: uppercase; }

    .panel-caption {
        position: absolute; bottom: 0; left: 0; right: 0;
        padding: 30px 26px 28px; z-index: 3;
        background: linear-gradient(to top, rgba(15,45,26,0.92) 0%, transparent 100%);
    }
    .panel-caption .quote { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.3rem; color: #e0f0e6; line-height: 1.45; margin-bottom: 10px; }
    .panel-caption .gold-line { width: 32px; height: 2px; background: var(--gold); border-radius: 2px; margin-bottom: 8px; }
    .panel-caption .meta { font-size: 0.7rem; color: rgba(178,223,202,0.6); letter-spacing: 0.14em; text-transform: uppercase; }

    /* Form Panel */
    .panel-form { flex: 1; background: var(--cream); padding: 44px 40px; display: flex; flex-direction: column; justify-content: center; }

    .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; }
    .brand-logo { width: 38px; height: 38px; background: var(--green-800); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; box-shadow: 0 4px 12px rgba(15,45,26,0.3); }
    .brand-text .name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: var(--green-800); display: block; }
    .brand-text .sub  { font-size: 0.65rem; color: var(--text-light); letter-spacing: 0.12em; text-transform: uppercase; display: block; }

    .form-title    { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; color: var(--text-dark); line-height: 1.1; margin-bottom: 4px; }
    .form-subtitle { font-size: 0.85rem; color: var(--text-light); font-weight: 300; margin-bottom: 28px; }

    .field { margin-bottom: 18px; }
    .field label { display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green-700); margin-bottom: 7px; }
    .field-wrap { position: relative; }
    .field-wrap .ficon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 13px; pointer-events: none; opacity: 0.45; }
    .field-wrap input {
        width: 100%; padding: 12px 16px 12px 40px;
        background: var(--white); border: 1.5px solid var(--border); border-radius: 10px;
        font-family: 'Outfit', sans-serif; font-size: 0.88rem; color: var(--text-dark); outline: none;
        transition: border-color 0.22s, box-shadow 0.22s;
    }
    .field-wrap input:focus { border-color: var(--green-500); box-shadow: 0 0 0 3px rgba(58,140,82,0.12); }
    .field-wrap input::placeholder { color: #c0ccc5; font-weight: 300; }
    .text-danger { font-size: 0.72rem; margin-top: 4px; color: #c0392b !important; }

    .row-forgot { display: flex; justify-content: flex-end; margin-bottom: 20px; margin-top: -6px; }
    .forgot-link { font-size: 0.78rem; color: var(--green-500); text-decoration: none; font-weight: 500; transition: color 0.18s; }
    .forgot-link:hover { color: var(--green-800); text-decoration: underline; }

    .btn-signin {
        width: 100%; padding: 13px;
        background: linear-gradient(135deg, var(--green-800) 0%, var(--green-500) 100%);
        color: #fff; border: none; border-radius: 10px;
        font-family: 'Outfit', sans-serif; font-size: 0.92rem; font-weight: 600; letter-spacing: 0.04em;
        cursor: pointer; position: relative; overflow: hidden;
        transition: transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 6px 20px rgba(26,66,40,0.35);
    }
    .btn-signin::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0) 100%); transform: translateX(-100%); transition: transform 0.5s ease; }
    .btn-signin:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(26,66,40,0.4); }
    .btn-signin:hover::after { transform: translateX(100%); }
    .btn-signin:active { transform: translateY(0); }

    .server-error { font-size: 0.78rem; color: #c0392b; text-align: center; margin-top: 8px; }

    .or-divider { display: flex; align-items: center; gap: 12px; margin: 16px 0; }
    .or-divider::before, .or-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .or-divider span { font-size: 0.7rem; color: #b0c0b5; font-weight: 500; }

    .btn-google {
        width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px;
        padding: 11px; background: var(--white); border: 1.5px solid var(--border); border-radius: 10px;
        font-family: 'Outfit', sans-serif; font-size: 0.86rem; font-weight: 500; color: var(--text-dark);
        text-decoration: none; cursor: pointer; transition: border-color 0.18s, box-shadow 0.18s, transform 0.15s;
    }
    .btn-google:hover { border-color: #c0d5cc; box-shadow: 0 4px 14px rgba(0,0,0,0.07); transform: translateY(-1px); color: var(--text-dark); }
    .btn-google img { width: 18px; }

    .demo-box { margin-top: 14px; padding: 12px 14px; background: rgba(58,140,82,0.06); border: 1.5px dashed rgba(58,140,82,0.28); border-radius: 10px; }
    .demo-box .demo-head { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); margin-bottom: 8px; }
    .demo-row { display: flex; gap: 8px; }
    .demo-row select { flex: 1; padding: 8px 12px; border: 1.5px solid var(--border); border-radius: 8px; background: var(--white); font-family: 'Outfit', sans-serif; font-size: 0.82rem; color: var(--text-dark); outline: none; cursor: pointer; }
    .demo-row select:focus { border-color: var(--green-500); }
    .btn-demo { padding: 8px 16px; background: var(--green-800); color: #fff; border: none; border-radius: 8px; font-family: 'Outfit', sans-serif; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: background 0.18s, transform 0.15s; }
    .btn-demo:hover { background: var(--green-700); transform: translateY(-1px); }

    .signup-row { margin-top: 18px; text-align: center; font-size: 0.8rem; color: var(--text-light); font-weight: 300; }
    .signup-row a { color: var(--green-700); font-weight: 600; text-decoration: none; border-bottom: 1.5px solid transparent; transition: border-color 0.18s, color 0.18s; }
    .signup-row a:hover { color: var(--green-800); border-color: var(--green-700); }

    @media (max-width: 700px) {
        .panel-image { display: none; }
        .panel-form { padding: 36px 24px; }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="login-wrapper">
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>

    <div class="login-card">

        <!-- Left image panel -->
        <div class="panel-image">
            <div class="panel-image-overlay"></div>
            <div class="badge-organic">
                <div class="pulse"></div>
                <span>100% Organic</span>
            </div>
            <img src="https://images.unsplash.com/photo-1603892349429-5a29aabe9dc8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=MnwzNjUyOXwwfDF8c2VhcmNofDF8fG9yZ2FuaWN8fDB8fHx8MTY1MjAwNzQyOQ&ixlib=rb-1.2.1&q=80&w=1080" alt="Fresh organic produce">
            <div class="panel-caption">
                <div class="quote">"Farm fresh, always.<br>Nature on your table."</div>
                <div class="gold-line"></div>
                <div class="meta">Farm to Table · Est. 2020</div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="panel-form">

            <div class="brand">
                <div class="brand-logo">🌱</div>
                <div class="brand-text">
                    <span class="name">Organic Store</span>
                    <span class="sub">Pure · Fresh · Natural</span>
                </div>
            </div>

            <h1 class="form-title">Welcome back</h1>
            <p class="form-subtitle">Sign in to your account to continue</p>

            <form method="POST" action="/login" id="loginForm" autocomplete="off">

                <div class="field">
                    <label for="email">Email Address</label>
                    <div class="field-wrap">
                        <input type="email" id="email" name="email" placeholder="you@example.com" required>
                        <span class="ficon">✉</span>
                    </div>
                    <div id="emailError" class="text-danger"></div>
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <div class="field-wrap">
                        <input type="password" id="password" name="password" placeholder="Min. 6 characters" minlength="6" required>
                        <span class="ficon">🔒</span>
                    </div>
                    <div id="passwordError" class="text-danger"></div>
                </div>

                <div class="row-forgot">
                    <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn-signin">Sign In</button>

                <% if (message) { %>
                    <p class="server-error"><%= message %></p>
                <% } %>

                <div class="or-divider"><span>or continue with</span></div>

                <a href="/auth/google" class="btn-google">
                    <img src="images/googlesignup.png" alt="Google Logo">
                    Continue with Google
                </a>

                <div class="demo-box">
                    <div class="demo-head">🎮 Try a Demo Account</div>
                    <div class="demo-row">
                        <select id="role" name="role" required>
                            <option value="user">Demo User</option>
                            <option value="admin">Demo Admin</option>
                        </select>
                        <button type="button" id="demoLoginButton" class="btn-demo">Enter Demo</button>
                    </div>
                </div>

            </form>

            <div class="signup-row">
                Don't have an account? <a href="/signup">Create one free</a>
            </div>

        </div>
    </div>
</div>

<script>
    const form = document.getElementById('loginForm');
    const email = document.getElementById('email');
    const password = document.getElementById('password');
    const emailError = document.getElementById('emailError');
    const passwordError = document.getElementById('passwordError');

    document.getElementById('demoLoginButton').addEventListener('click', function () {
        const role = document.getElementById('role').value;
        if (role === 'user') {
            window.location.href = '/demoUser';
        } else if (role === 'admin') {
            window.location.href = "/admin/demoAdmin";
        }
    });

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{6,}$/;

    form.addEventListener('submit', function(event) {
        let valid = true;
        emailError.textContent = '';
        passwordError.textContent = '';

        if (email.value.trim() === '') {
            emailError.textContent = 'Email is required.';
            valid = false;
        } else if (!emailRegex.test(email.value)) {
            emailError.textContent = 'Please enter a valid email address.';
            valid = false;
        }

        if (password.value.trim() === '') {
            passwordError.textContent = 'Password is required.';
            valid = false;
        } else if (password.value.length < 6) {
            passwordError.textContent = 'Password must be at least 6 characters long.';
            valid = false;
        } else if (!passwordRegex.test(password.value)) {
            passwordError.textContent = 'Password must contain at least one uppercase letter, one lowercase letter, one digit, and one special character.';
            valid = false;
        }

        if (!valid) {
            event.preventDefault();
        }
    });
</script>

<script>
    window.onload = function() {
        document.getElementById('email').value = '';
        document.getElementById('password').value = '';
    };
</script>