<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Available Coupons</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #f5f0e8;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-content {
      flex: 1;
      padding: 56px 32px 72px;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.6rem;
      color: #1a1a2e;
      text-align: center;
      margin-bottom: 8px;
      letter-spacing: -0.5px;
    }

    .page-subtitle {
      text-align: center;
      color: #888;
      font-size: 0.95rem;
      margin-bottom: 48px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .coupon-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 28px;
    }

    .coupon-card {
      background: #fff;
      border-radius: 16px;
      overflow: visible;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
      display: flex;
      flex-direction: column;
      position: relative;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .coupon-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.13);
    }

    /* Dashed tear line */
    .coupon-card::after {
      content: '';
      position: absolute;
      left: 14px; right: 14px;
      top: 88px;
      border-top: 2px dashed #e2ddd4;
      z-index: 1;
    }

    /* Left cutout circle */
    .coupon-card::before {
      content: '';
      position: absolute;
      top: 74px;
      left: -14px;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: #f5f0e8;
      z-index: 2;
    }

    /* Right cutout circle */
    .cutout-right {
      position: absolute;
      top: 74px;
      right: -14px;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: #f5f0e8;
      z-index: 2;
      pointer-events: none;
    }

    .coupon-header {
      padding: 22px 24px;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      border-radius: 16px 16px 0 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      min-height: 88px;
    }

    .coupon-badge {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 0.72rem;
      color: #c8b89a;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }

    .coupon-code {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      color: #fff;
      letter-spacing: 2px;
    }

    .coupon-body {
      padding: 28px 24px 20px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .coupon-description {
      color: #4a4a6a;
      font-size: 0.92rem;
      line-height: 1.6;
      flex: 1;
    }

    .coupon-meta {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.78rem;
      color: #aaa;
      font-weight: 500;
    }

    .clock-icon {
      width: 13px; height: 13px;
      display: inline-block;
      flex-shrink: 0;
    }

    .btn-apply {
      margin: 0 24px 24px;
      background: linear-gradient(135deg, #d4a843, #c49030);
      color: #1a1a2e;
      border: none;
      border-radius: 10px;
      padding: 12px 0;
      width: calc(100% - 48px);
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 0.88rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
      transition: opacity 0.2s ease, transform 0.15s ease;
    }

    .btn-apply:hover {
      opacity: 0.9;
      transform: scale(0.99);
    }

    .empty-state {
      text-align: center;
      padding: 80px 20px;
      color: #aaa;
      grid-column: 1 / -1;
      font-size: 1.05rem;
    }
  </style>
</head>
<body>

  <%- include("../partials/user/header") %>

  <div class="page-content">
    <h1 class="page-title">Available Coupons</h1>
    <p class="page-subtitle">Exclusive deals just for you</p>

    <div class="coupon-grid">
      <% if (coupon.length > 0) { %>
        <% coupon.forEach(function(c) { %>
          <div class="coupon-card">
            <div class="cutout-right"></div>
            <div class="coupon-header">
              <div class="coupon-code"><%= c.code %></div>
              <div class="coupon-badge">Offer</div>
            </div>
            <div class="coupon-body">
              <div class="coupon-description"><%= c.description %></div>
              <div class="coupon-meta">
                <svg class="clock-icon" fill="none" viewBox="0 0 24 24" stroke="#c49030" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                Valid until: <%= new Date(c.expiryDate).toLocaleDateString() %>
              </div>
            </div>
            
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">No coupons available at the moment.</div>
      <% } %>
    </div>
  </div>

  <%- include("../../views/partials/user/footer") %>

  <script>
    function applyCoupon(code) {
      window.location.href = '/order/checkout/?couponCode=' + code;
    }
  </script>
</body>
</html>