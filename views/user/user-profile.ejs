
<%- include("../../views/partials/user/header") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<script>
  const s = document.createElement('style');
  s.textContent = `
    body { background: #faf7f0 !important; font-family: 'DM Sans', sans-serif !important; }

    .profile-page {
      max-width: 1000px;
      margin: 100px auto 60px;
      padding: 0 24px;
    }

    /* ── PAGE TITLE ── */
    .profile-title {
      font-family: 'Playfair Display', serif !important;
      font-size: 2rem !important;
      color: #1a3c2e !important;
      display: flex !important;
      align-items: center !important;
      gap: 12px !important;
      margin-bottom: 32px !important;
    }
    .profile-title i { color: #52b788 !important; }

    /* ── SECTION CARDS ── */
    .pro-card {
      background: #fff !important;
      border-radius: 14px !important;
      border: 1px solid #e0ece5 !important;
      box-shadow: 0 4px 24px rgba(26,60,46,0.08) !important;
      overflow: hidden !important;
      margin-bottom: 28px !important;
    }
    .pro-card-header {
      background: linear-gradient(135deg, #1a3c2e, #2d6a4f) !important;
      padding: 13px 22px !important;
      display: flex !important;
      align-items: center !important;
      gap: 10px !important;
    }
    .pro-card-header h4 {
      font-family: 'Playfair Display', serif !important;
      color: #fff !important;
      font-size: 1rem !important;
      margin: 0 !important;
      font-weight: 600 !important;
    }
    .pro-card-header i { color: #52b788 !important; font-size: 13px !important; }
    .pro-card-body { padding: 22px !important; }

    /* ── USER INFO ── */
    .user-info-grid {
      display: grid !important;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)) !important;
      gap: 14px !important;
      margin-bottom: 20px !important;
    }
    .info-pill {
      background: #d8f3dc !important;
      border-radius: 10px !important;
      padding: 14px 18px !important;
    }
    .info-pill .pill-label {
      font-size: 10.5px !important;
      text-transform: uppercase !important;
      letter-spacing: 1.2px !important;
      color: #2d6a4f !important;
      font-weight: 600 !important;
      margin-bottom: 5px !important;
      display: block !important;
    }
    .info-pill .pill-value {
      font-size: 14.5px !important;
      font-weight: 600 !important;
      color: #1a3c2e !important;
    }
    .referral-pill {
      background: #fff8e6 !important;
      border: 1px solid #ffe082 !important;
      border-radius: 10px !important;
      padding: 12px 18px !important;
      display: flex !important;
      align-items: center !important;
      gap: 10px !important;
    }
    .referral-pill i { color: #c9a84c !important; }
    .referral-pill .r-label { font-size: 11px !important; color: #8a6200 !important; font-weight: 600 !important; letter-spacing: 1px !important; text-transform: uppercase !important; display: block !important; }
    .referral-pill .r-code { font-size: 15px !important; font-weight: 700 !important; color: #7a5500 !important; letter-spacing: 2px !important; }

    .btn-wallet {
      display: inline-flex !important;
      align-items: center !important;
      gap: 7px !important;
      background: linear-gradient(135deg, #52b788, #2d6a4f) !important;
      color: #fff !important;
      border-radius: 100px !important;
      padding: 9px 22px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      font-weight: 500 !important;
      text-decoration: none !important;
      box-shadow: 0 4px 14px rgba(45,106,79,0.25) !important;
      transition: opacity 0.2s !important;
      margin-top: 8px !important;
    }
    .btn-wallet:hover { opacity: 0.88 !important; color: #fff !important; }

    /* ── ADDRESS CARDS ── */
    .address-item {
      background: #f8fdf9 !important;
      border: 1px solid #e0ece5 !important;
      border-radius: 12px !important;
      padding: 18px 20px !important;
      margin-bottom: 16px !important;
      position: relative !important;
    }
    .address-item:last-child { margin-bottom: 0 !important; }

    .address-top {
      display: flex !important;
      align-items: flex-start !important;
      justify-content: space-between !important;
      gap: 12px !important;
      margin-bottom: 14px !important;
      flex-wrap: wrap !important;
    }
    .address-text {
      font-size: 14px !important;
      color: #3a5244 !important;
      line-height: 1.6 !important;
      flex: 1 !important;
    }
    .badge-default {
      display: inline-flex !important;
      align-items: center !important;
      gap: 5px !important;
      background: #e8f5e9 !important;
      color: #2e7d32 !important;
      border: 1px solid #a5d6a7 !important;
      border-radius: 100px !important;
      padding: 4px 12px !important;
      font-size: 11.5px !important;
      font-weight: 600 !important;
      white-space: nowrap !important;
    }
    .btn-set-default {
      display: inline-flex !important;
      align-items: center !important;
      gap: 5px !important;
      background: transparent !important;
      color: #2d6a4f !important;
      border: 1.5px solid #2d6a4f !important;
      border-radius: 100px !important;
      padding: 4px 14px !important;
      font-size: 12px !important;
      font-weight: 500 !important;
      font-family: 'DM Sans', sans-serif !important;
      cursor: pointer !important;
      white-space: nowrap !important;
      transition: background 0.18s, color 0.18s !important;
    }
    .btn-set-default:hover { background: #2d6a4f !important; color: #fff !important; }

    /* edit form inside address */
    .edit-form-grid {
      display: grid !important;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)) !important;
      gap: 10px !important;
      margin-top: 14px !important;
    }
    .edit-form-grid .form-control {
      border: 1.5px solid #d0e6d8 !important;
      border-radius: 10px !important;
      padding: 8px 12px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      color: #1a3c2e !important;
      background: #fff !important;
      outline: none !important;
    }
    .edit-form-grid .form-control:focus { border-color: #52b788 !important; box-shadow: 0 0 0 3px rgba(82,183,136,0.12) !important; }

    .address-btn-row {
      display: flex !important;
      gap: 8px !important;
      margin-top: 12px !important;
      flex-wrap: wrap !important;
    }
    .btn-edit-submit {
      display: inline-flex !important;
      align-items: center !important;
      gap: 6px !important;
      background: #2d6a4f !important;
      color: #fff !important;
      border: none !important;
      border-radius: 10px !important;
      padding: 8px 20px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13px !important;
      font-weight: 500 !important;
      cursor: pointer !important;
      transition: opacity 0.18s !important;
    }
    .btn-edit-submit:hover { opacity: 0.88 !important; }

    .btn-delete {
      display: inline-flex !important;
      align-items: center !important;
      gap: 6px !important;
      background: #fdecea !important;
      color: #b71c1c !important;
      border: 1.5px solid #ef9a9a !important;
      border-radius: 10px !important;
      padding: 8px 18px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13px !important;
      font-weight: 500 !important;
      cursor: pointer !important;
      transition: background 0.18s !important;
    }
    .btn-delete:hover { background: #f5c6c6 !important; }

    .error-msg { color: #c0392b !important; font-size: 13px !important; margin-top: 8px !important; display: block !important; }

    /* ── ADD ADDRESS FORM ── */
    .add-form-grid {
      display: grid !important;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)) !important;
      gap: 12px !important;
      margin-bottom: 14px !important;
    }
    .add-form-grid .form-control {
      border: 1.5px solid #d0e6d8 !important;
      border-radius: 10px !important;
      padding: 10px 14px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      color: #1a3c2e !important;
      background: #fff !important;
      outline: none !important;
      width: 100% !important;
    }
    .add-form-grid .form-control:focus { border-color: #52b788 !important; box-shadow: 0 0 0 3px rgba(82,183,136,0.12) !important; }

    .btn-add-address {
      display: inline-flex !important;
      align-items: center !important;
      gap: 7px !important;
      background: linear-gradient(135deg, #52b788, #2d6a4f) !important;
      color: #fff !important;
      border: none !important;
      border-radius: 10px !important;
      padding: 10px 22px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      font-weight: 500 !important;
      cursor: pointer !important;
      box-shadow: 0 4px 14px rgba(45,106,79,0.22) !important;
      transition: opacity 0.18s !important;
    }
    .btn-add-address:hover { opacity: 0.88 !important; }

    .btn-add-more {
      display: inline-flex !important;
      align-items: center !important;
      gap: 7px !important;
      background: transparent !important;
      color: #2d6a4f !important;
      border: 1.5px solid #2d6a4f !important;
      border-radius: 10px !important;
      padding: 10px 20px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      font-weight: 500 !important;
      cursor: pointer !important;
      transition: background 0.18s, color 0.18s !important;
    }
    .btn-add-more:hover { background: #2d6a4f !important; color: #fff !important; }

    .btn-remove-addr {
      display: inline-flex !important;
      align-items: center !important;
      gap: 6px !important;
      background: #fdecea !important;
      color: #b71c1c !important;
      border: 1.5px solid #ef9a9a !important;
      border-radius: 10px !important;
      padding: 8px 16px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13px !important;
      cursor: pointer !important;
      transition: background 0.18s !important;
    }
    .btn-remove-addr:hover { background: #f5c6c6 !important; }

    /* ── PASSWORD SECTION ── */
    .password-input-row {
      display: flex !important;
      gap: 10px !important;
      flex-wrap: wrap !important;
    }
    .password-input-row .form-control {
      flex: 1 !important;
      min-width: 200px !important;
      border: 1.5px solid #d0e6d8 !important;
      border-radius: 10px !important;
      padding: 10px 14px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      color: #1a3c2e !important;
      outline: none !important;
    }
    .password-input-row .form-control:focus { border-color: #52b788 !important; box-shadow: 0 0 0 3px rgba(82,183,136,0.12) !important; }

    .btn-reset {
      display: inline-flex !important;
      align-items: center !important;
      gap: 7px !important;
      background: #f0f5f2 !important;
      color: #2d6a4f !important;
      border: 1.5px solid #b7e4c7 !important;
      border-radius: 10px !important;
      padding: 10px 22px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13.5px !important;
      font-weight: 500 !important;
      cursor: pointer !important;
      white-space: nowrap !important;
      transition: background 0.18s !important;
    }
    .btn-reset:hover { background: #d8f3dc !important; }

    .section-sub {
      font-family: 'Playfair Display', serif !important;
      font-size: 1.05rem !important;
      color: #1a3c2e !important;
      margin: 0 0 16px 0 !important;
      display: block !important;
    }

    .no-addr { font-size: 14px !important; color: #6b8c78 !important; }

    @media (max-width: 600px) {
      .profile-page { padding: 0 14px !important; margin-top: 80px !important; }
    }
  `;
  document.head.appendChild(s);
</script>

<div class="profile-page">

  <!-- ── USER INFO ── -->
  <h1 class="profile-title"><i class="fas fa-user-circle"></i> User Profile</h1>

  <div class="pro-card">
    <div class="pro-card-header">
      <i class="fas fa-id-card"></i>
      <h4>Account Information</h4>
    </div>
    <div class="pro-card-body">
      <div class="user-info-grid">
        <div class="info-pill">
          <span class="pill-label">Username</span>
          <span class="pill-value"><i class="fas fa-user" style="margin-right:6px; color:#52b788; font-size:12px;"></i><%= user.username %></span>
        </div>
        <div class="info-pill">
          <span class="pill-label">Email</span>
          <span class="pill-value" style="font-size:13px;"><i class="fas fa-envelope" style="margin-right:6px; color:#52b788; font-size:12px;"></i><%= user.email %></span>
        </div>
        <div class="referral-pill">
          <i class="fas fa-gift"></i>
          <div>
            <span class="r-label">Referral Code</span>
            <span class="r-code"><%= user.referralCode %></span>
          </div>
        </div>
      </div>
      <a href="/wallet" class="btn-wallet">
        <i class="fas fa-wallet"></i> Go to Wallet
      </a>
    </div>
  </div>

  <!-- ── ADDRESSES ── -->
  <div class="pro-card">
    <div class="pro-card-header">
      <i class="fas fa-map-marker-alt"></i>
      <h4>My Addresses</h4>
    </div>
    <div class="pro-card-body">

      <% if(user.addresses && user.addresses.length > 0) { %>
        <% user.addresses.forEach(address => { %>
          <div class="address-item">

            <div class="address-top">
              <div class="address-text">
                <i class="fas fa-home" style="color:#52b788; margin-right:6px;"></i>
                <%= address.fullName %>, <%= address.address %>, <%= address.city %>, <%= address.country %> - <%= address.postalCode %>
              </div>
              <% if (user.defaultAddress && address._id.toString() === user.defaultAddress.toString()) { %>
                <span class="badge-default"><i class="fas fa-check-circle"></i> Default</span>
              <% } else { %>
                <form action="/profile/set-default-address/<%= address._id %>" method="POST" style="margin:0;">
                  <button type="submit" class="btn-set-default"><i class="fas fa-map-pin"></i> Set Default</button>
                </form>
              <% } %>
            </div>

            <!-- Edit Form -->
            <form action="/profile/edit-address/<%= address._id %>" method="POST" id="edit-address-form">
              <div class="edit-form-grid">
                <input type="text" class="form-control" name="fullName" value="<%= address.fullName %>" placeholder="Full Name" id="editFullName">
                <input type="text" class="form-control" name="address" value="<%= address.address %>" placeholder="Address" id="editAddress">
                <input type="text" class="form-control" name="city" value="<%= address.city %>" placeholder="City" id="editCity">
                <input type="text" class="form-control" name="postalCode" value="<%= address.postalCode %>" placeholder="Postal Code" id="editPostalCode">
                <input type="text" class="form-control" name="country" value="<%= address.country %>" placeholder="Country" id="editCountry">
              </div>
              <div id="editAddressErrors" class="error-msg"></div>
              <div class="address-btn-row">
                <button type="submit" class="btn-edit-submit"><i class="fas fa-save"></i> Save Changes</button>
                <form action="/profile/delete-address/<%= address._id %>" method="POST" style="margin:0;" onsubmit="return confirmDelete('address')">
                  <button type="submit" class="btn-delete"><i class="fas fa-trash-alt"></i> Delete</button>
                </form>
              </div>
            </form>

          </div>
        <% }) %>
      <% } else { %>
        <p class="no-addr"><i class="fas fa-map-marker-alt" style="margin-right:6px; opacity:0.4;"></i>No addresses found.</p>
      <% } %>

      <!-- Add New Address -->
      <div style="margin-top: 28px; padding-top: 20px; border-top: 1px dashed #d0e6d8;">
        <span class="section-sub"><i class="fas fa-plus-circle" style="color:#52b788; margin-right:8px;"></i>Add New Address</span>
        <form id="address-form" action="/profile/add-address" method="POST">
          <div class="add-form-grid">
            <input type="text" name="fullName[]" class="form-control" placeholder="Full Name" required>
            <input type="text" name="address[]" class="form-control" placeholder="Address" required>
            <input type="text" name="city[]" class="form-control" placeholder="City" required>
            <input type="text" name="postalCode[]" class="form-control" placeholder="Postal Code" required>
            <input type="text" name="country[]" class="form-control" placeholder="Country" required>
          </div>
          <div id="addAddressErrors" class="error-msg"></div>
          <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:4px;">
            <button type="submit" class="btn-add-address"><i class="fas fa-plus"></i> Add Address</button>
            <button type="button" id="add-address-btn" class="btn-add-more"><i class="fas fa-copy"></i> Add Another</button>
          </div>
        </form>
        <div id="additional-addresses"></div>
      </div>

    </div>
  </div>

  <!-- ── FORGOT PASSWORD ── -->
  <div class="pro-card">
    <div class="pro-card-header">
      <i class="fas fa-lock"></i>
      <h4>Reset Password</h4>
    </div>
    <div class="pro-card-body">
      <form action="/forgot-email-valid" method="POST">
        <div class="password-input-row">
          <input type="email" name="email" class="form-control" placeholder="Enter your email address" required>
          <button type="submit" class="btn-reset"><i class="fas fa-paper-plane"></i> Send Reset Link</button>
        </div>
        <div id="forgotPasswordErrors" class="error-msg"></div>
      </form>
    </div>
  </div>

</div>

<script>
  function confirmDelete(item) {
    return confirm(`Are you sure you want to delete this ${item}?`);
  }

  document.getElementById('add-address-btn').addEventListener('click', function() {
    const additionalAddresses = document.getElementById('additional-addresses');
    const newAddressForm = `
      <div class="row g-3 mt-3" style="margin-top:14px; padding:16px; background:#f8fdf9; border-radius:12px; border:1px solid #e0ece5;">
        <div class="add-form-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:10px;">
          <input type="text" name="fullName[]" class="form-control" placeholder="Full Name" required style="border:1.5px solid #d0e6d8; border-radius:10px; padding:10px 14px; font-size:13.5px; width:100%;">
          <input type="text" name="address[]" class="form-control" placeholder="Address" required style="border:1.5px solid #d0e6d8; border-radius:10px; padding:10px 14px; font-size:13.5px; width:100%;">
          <input type="text" name="city[]" class="form-control" placeholder="City" required style="border:1.5px solid #d0e6d8; border-radius:10px; padding:10px 14px; font-size:13.5px; width:100%;">
          <input type="text" name="postalCode[]" class="form-control" placeholder="Postal Code" required style="border:1.5px solid #d0e6d8; border-radius:10px; padding:10px 14px; font-size:13.5px; width:100%;">
          <input type="text" name="country[]" class="form-control" placeholder="Country" required style="border:1.5px solid #d0e6d8; border-radius:10px; padding:10px 14px; font-size:13.5px; width:100%;">
        </div>
        <div style="margin-top:10px;">
          <button type="button" class="remove-address btn-remove-addr" style="display:inline-flex; align-items:center; gap:6px; background:#fdecea; color:#b71c1c; border:1.5px solid #ef9a9a; border-radius:10px; padding:8px 16px; font-size:13px; cursor:pointer;">
            <i class="fas fa-times"></i> Remove
          </button>
        </div>
      </div>
    `;
    additionalAddresses.insertAdjacentHTML('beforeend', newAddressForm);
  });

  document.getElementById('additional-addresses').addEventListener('click', function(event) {
    if (event.target.classList.contains('remove-address') || event.target.closest('.remove-address')) {
      event.target.closest('.row').remove();
    }
  });

  document.getElementById('address-form').addEventListener('submit', function(event) {
    let errors = [];
    let formValid = true;
    const fullNames = document.getElementsByName('fullName[]');
    const addresses = document.getElementsByName('address[]');
    const cities = document.getElementsByName('city[]');
    const postalCodes = document.getElementsByName('postalCode[]');
    const countries = document.getElementsByName('country[]');
    const addressRegex = /[A-Za-z]/;
    const postalCodeRegex = /^[A-Za-z0-9 ]+$/;

    for (let i = 0; i < fullNames.length; i++) {
      const fullName = fullNames[i].value.trim();
      const address = addresses[i].value.trim();
      const city = cities[i].value.trim();
      const postalCode = postalCodes[i].value.trim();
      const country = countries[i].value.trim();
      if (!fullName) { errors.push(`Full name is required for address #${i + 1}.`); formValid = false; }
      if (!address) { errors.push(`Address is required.`); formValid = false; }
      else if (!addressRegex.test(address)) { errors.push(`Address must contain letters.`); formValid = false; }
      if (!city) { errors.push(`City is required.`); formValid = false; }
      if (!postalCode) { errors.push(`Postal code is required.`); formValid = false; }
      else if (!postalCodeRegex.test(postalCode)) { errors.push(`Postal code must be alphanumeric.`); formValid = false; }
      if (!country) { errors.push(`Country is required.`); formValid = false; }
    }

    if (!formValid) {
      event.preventDefault();
      document.getElementById('addAddressErrors').innerHTML = errors.join('<br>');
    } else {
      document.getElementById('addAddressErrors').innerHTML = '';
    }
  });

  document.addEventListener('DOMContentLoaded', function() {
    const editForm = document.getElementById('edit-address-form');
    if (editForm) {
      editForm.addEventListener('submit', function(event) {
        const fullName = document.getElementById('editFullName').value.trim();
        const address = document.getElementById('editAddress').value.trim();
        const city = document.getElementById('editCity').value.trim();
        const postalCode = document.getElementById('editPostalCode').value.trim();
        const country = document.getElementById('editCountry').value.trim();
        let errors = [];
        const addressRegex = /[A-Za-z]/;
        const postalCodeRegex = /^[A-Za-z0-9 ]+$/;
        if (!fullName) errors.push('Full name is required.');
        if (!address) errors.push('Address is required.');
        else if (!addressRegex.test(address)) errors.push('Address must contain letters.');
        if (!city) errors.push('City is required.');
        if (!postalCode) errors.push('Postal code is required.');
        else if (!postalCodeRegex.test(postalCode)) errors.push('Postal code must be alphanumeric.');
        if (!country) errors.push('Country is required.');
        if (errors.length > 0) {
          event.preventDefault();
          document.getElementById('editAddressErrors').innerHTML = errors.join('<br>');
        } else {
          document.getElementById('editAddressErrors').innerHTML = '';
        }
      });
    }
  });
</script>

<%- include("../../views/partials/user/footer") %>