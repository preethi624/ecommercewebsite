<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organic Store</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/home.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --green-dark:  #1a3c2e;
            --green-mid:   #2d6a4f;
            --green-light: #52b788;
            --green-pale:  #d8f3dc;
        }

        * { box-sizing: border-box; }

        /* ── NAVBAR ── */
        .custom-navbar {
            background: linear-gradient(135deg, #1a3c2e 0%, #2d6a4f 100%) !important;
            padding: 0 32px !important;
            height: 68px;
            box-shadow: 0 2px 20px rgba(0,0,0,0.18);
            font-family: 'DM Sans', sans-serif;
        }

        .navbar-brand img {
            height: 46px;
            object-fit: contain;
            filter: brightness(0) invert(1);
        }

        /* ── LEFT NAV LINKS ── */
        .nav-left .nav-link {
            color: rgba(255,255,255,0.82) !important;
            font-size: 14px;
            font-weight: 500;
            padding: 6px 14px !important;
            border-radius: 8px;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
        }
        .nav-left .nav-link:hover {
            background: rgba(255,255,255,0.12);
            color: #fff !important;
        }

        /* ── RIGHT ICON BUTTONS ── */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .nav-icon-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            color: rgba(255,255,255,0.82);
            text-decoration: none;
            font-size: 16px;
            transition: background 0.18s, color 0.18s;
            position: relative;
        }
        .nav-icon-btn:hover {
            background: rgba(255,255,255,0.14);
            color: #fff;
            text-decoration: none;
        }

        /* tooltip on hover */
        .nav-icon-btn::after {
            content: attr(data-tip);
            position: absolute;
            bottom: -30px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--green-dark);
            color: #fff;
            font-size: 11px;
            font-family: 'DM Sans', sans-serif;
            white-space: nowrap;
            padding: 3px 8px;
            border-radius: 6px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.15s;
            z-index: 999;
        }
        .nav-icon-btn:hover::after { opacity: 1; }

        /* ── DIVIDER ── */
        .nav-divider {
            width: 1px;
            height: 22px;
            background: rgba(255,255,255,0.18);
            margin: 0 6px;
        }

        /* ── USER DROPDOWN ── */
        .user-dropdown-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.10);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 100px;
            padding: 5px 14px 5px 7px;
            color: rgba(255,255,255,0.92) !important;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.18s;
            white-space: nowrap;
            max-width: 180px;
        }
        .user-dropdown-toggle:hover {
            background: rgba(255,255,255,0.18);
            color: #fff !important;
            text-decoration: none;
        }
        .user-dropdown-toggle .user-avatar {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: var(--green-light);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; color: #fff;
            flex-shrink: 0;
        }
        .user-dropdown-toggle .user-name {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        /* hide bootstrap caret */
        .user-dropdown-toggle::after { display: none; }

        .dropdown-menu {
            border: none;
            border-radius: 14px;
            box-shadow: 0 8px 32px rgba(26,60,46,0.15);
            padding: 8px;
            min-width: 180px;
            margin-top: 8px !important;
        }
        .dropdown-item {
            border-radius: 8px;
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            color: #2d4a38;
            padding: 9px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: background 0.15s;
        }
        .dropdown-item i { width: 16px; text-align: center; color: var(--green-mid); font-size: 13px; }
        .dropdown-item:hover { background: var(--green-pale); color: var(--green-dark); }
        .dropdown-item.logout { color: #c0392b; }
        .dropdown-item.logout i { color: #c0392b; }

        /* ── AUTH BUTTONS ── */
        .btn-auth-outline {
            border: 1.5px solid rgba(255,255,255,0.40);
            color: rgba(255,255,255,0.90) !important;
            border-radius: 100px;
            padding: 6px 18px;
            font-size: 13.5px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            transition: background 0.18s, border-color 0.18s;
            white-space: nowrap;
        }
        .btn-auth-outline:hover {
            background: rgba(255,255,255,0.14);
            border-color: rgba(255,255,255,0.7);
            color: #fff !important;
            text-decoration: none;
        }
        .btn-auth-solid {
            background: var(--green-light);
            color: #fff !important;
            border-radius: 100px;
            padding: 6px 18px;
            font-size: 13.5px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            transition: opacity 0.18s;
            white-space: nowrap;
            border: none;
        }
        .btn-auth-solid:hover { opacity: 0.88; color: #fff !important; text-decoration: none; }

        /* ── TOGGLER ── */
        .navbar-toggler { border-color: rgba(255,255,255,0.4); }
        .navbar-toggler-icon { filter: invert(1); }

        /* ── DROPDOWN HOVER (desktop) ── */
        @media (min-width: 992px) {
            .dropdown:hover .dropdown-menu { display: block; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg custom-navbar">
    <div class="container-fluid">

        <!-- Brand -->
        <a class="navbar-brand" href="/">
            <img src="/images/organic-store-white-logo.png" alt="Logo">
        </a>

        <!-- Mobile toggler -->
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Nav content -->
        <div class="collapse navbar-collapse" id="navbarNav">

            <!-- Left links -->
            <ul class="navbar-nav nav-left me-auto">
                <li class="nav-item"><a href="/"        class="nav-link">Home</a></li>
                <li class="nav-item"><a href="/products" class="nav-link">Shop</a></li>
                <li class="nav-item"><a href="/about"   class="nav-link">About Us</a></li>
                <li class="nav-item"><a href="/contact" class="nav-link">Contact</a></li>
            </ul>

            <!-- Right icons -->
            <div class="nav-right">
                <% if (locals.user) { %>

                    <!-- Wallet icon -->
                    <a href="/wallet" class="nav-icon-btn" data-tip="Wallet">
                        <i class="fas fa-wallet"></i>
                    </a>

                    <!-- Orders icon -->
                    <a href="/orders" class="nav-icon-btn" data-tip="My Orders">
                        <i class="fas fa-box"></i>
                    </a>

                    <!-- Wishlist icon -->
                    <a href="/wishlist" class="nav-icon-btn" data-tip="Wishlist">
                        <i class="fas fa-heart"></i>
                    </a>

                    <!-- Cart icon -->
                    <a href="/cart" class="nav-icon-btn" data-tip="Cart">
                        <i class="fas fa-shopping-cart"></i>
                    </a>

                    <div class="nav-divider"></div>

                    <!-- User dropdown -->
                    <div class="dropdown">
                        <a href="#" class="user-dropdown-toggle dropdown-toggle"
                           id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="user-avatar"><i class="fas fa-user"></i></span>
                            <span class="user-name">
                                <% if (locals.user.googleEmail) { %>
                                    <%= locals.user.googleEmail %>
                                <% } else { %>
                                    <%= locals.user.username %>
                                <% } %>
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a href="/userProfile" class="dropdown-item"><i class="fas fa-user-circle"></i> My Profile</a></li>
                            <li><a href="/orders"      class="dropdown-item"><i class="fas fa-box"></i> Orders</a></li>
                            <li><a href="/wishlist"    class="dropdown-item"><i class="fas fa-heart"></i> Wishlist</a></li>
                            <li><a href="/getCoupons"  class="dropdown-item"><i class="fas fa-tag"></i> Coupons</a></li>
                            <li><hr class="dropdown-divider mx-2"></li>
                            <li><a href="/logOut"      class="dropdown-item logout"><i class="fas fa-sign-out-alt"></i> Log Out</a></li>
                        </ul>
                    </div>

                <% } else { %>
                    <a href="/signup" class="btn-auth-outline">Sign Up</a>
                    <a href="/login"  class="btn-auth-solid ms-2">Login</a>
                <% } %>
            </div>

        </div>
    </div>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>